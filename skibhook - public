local TestHitSound = function(sfx)
  task.spawn(function()
    if not getcustomasset(sfx) then
        return
    end

    local asset_id = getcustomasset(sfx)
    local sound = New("Sound", hideui)

    sound.SoundId = asset_id
    sound.Volume = library.flags["HitSoundVolume"]
    currenthitsound = sfx
    sound:Play()

    task.wait(3)
    sound:Destroy()
      
  end)
end




