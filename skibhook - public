function OnAdded(Player)
    if Player ~= Client then
        esplib:ESPObject(Player, library)
        library:notification({time = 2, text = "[SkibHook] " .. Player.Name .. " Joined The Server", flashing = false;})
    end
end



function OnRemoved(Player)
    if Player ~= Client then
        esplib:disconnect(Player)
        library:notification({time = 2, text = "[SkibHook] " .. Player.Name .. " Left The Server", flashing = false;})
    end
end



