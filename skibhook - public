local RenderFOV = function(Distance)
  local maxdist


  cheat.connections.silent = RunService.PreRender:Connect(function(deltatime)
  if library.flags["SilentAimToggle"] then
    services:framelimit(deltatime)
    local distance
    --setthreadlevel(8)


	cheat.visualcache.circle.Radius = library.flags["FOVRadius"]
    cheat.visualcache.circle.Color = library.flags["FOV_Color"].Color
    cheat.visualcache.circle.NumSides = library.flags["FOVNumSides"]
    cheat.visualcache.circle.Thickness = library.flags["Thickness"]
    cheat.visualcache.circle.Visible = library.flags["SilentAimToggle"] and library.flags["FOVToggle"]

    
    cheat.visualcache.outlinecircle.Radius = library.flags["FOVRadius"]
    cheat.visualcache.outlinecircle.Color = library.flags["Outline_Color"].Color
    cheat.visualcache.outlinecircle.NumSides = library.flags["FOVNumSides"]
    cheat.visualcache.outlinecircle.Thickness = library.flags["Thickness"] + 4
    cheat.visualcache.outlinecircle.Visible = library.flags["SilentAimToggle"] and library.flags["FOVToggle"] and library.flags["FOVOutline"]
    cheat.visualcache.outlinecircle.ZIndex = -25


    cheat.visualcache.circle.Position = CameraOrigin
    cheat.visualcache.outlinecircle.Position = CameraOrigin




    for _, P in Players:GetPlayers() do 
     if P == Client then continue end

    if P.Character and services:findfirstchild(P.Character, "Head") and services:findfirstchild(P.Character, "Humanoid") and library.get_priority(P) ~= "Friendly" then
      local targetP = P.Character["Head"]
      local pos2, os = services:wtvp(targetP.Position)
      local dist = (Vector2(mousePos.X, mousePos.Y) - Vector2(pos2.X, pos2.Y)).Magnitude


    

    if dist <= (distance or library.flags["FOVRadius"]) and os then
       Target = targetP
       distance = dist


     end
    end
   end
   

   else

    cheat.connections.silent:Disconnect()
    cheat.visualcache.circle.Visible = false
    cheat.visualcache.outlinecircle.Visible = false

  end
 end)
end




